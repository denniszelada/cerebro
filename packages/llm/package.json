{
  "name": "@cerebro/llm",
  "version": "1.0.0",
  "description": "Multi-provider LLM abstraction for Cerebro",
  "repository": {
    "type": "git",
    "url": "https://github.com/denniszelada/cerebro.git",
    "directory": "packages/llm"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "@google/genai": ">=1.0.0",
    "@google/generative-ai": ">=0.21.0",
    "@mistralai/mistralai": ">=1.0.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@mistralai/mistralai": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@google/genai": "^1.43.0",
    "@google/generative-ai": "^0.21.0",
    "@mistralai/mistralai": "^1.3.0",
    "openai": "^4.77.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
