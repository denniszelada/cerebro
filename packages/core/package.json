{
  "name": "@denniszelada/cerebro-core",
  "version": "1.0.0",
  "description": "Core types, Brain, Expert, Gateway, and Pipeline for Cerebro agentic framework",
  "repository": {
    "type": "git",
    "url": "https://github.com/denniszelada/cerebro.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/@denniszelada"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@denniszelada/cerebro-bus": "workspace:*",
    "@denniszelada/cerebro-knowledge": "workspace:*",
    "@denniszelada/cerebro-llm": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
